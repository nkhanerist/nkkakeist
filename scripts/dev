#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    cat <<'USAGE'
Usage:
  scripts/dev php <args...>
  scripts/dev composer <args...>
  scripts/dev artisan <args...>
  scripts/dev npm <args...>
  scripts/dev npx <args...>
  scripts/dev mysql <args...>
  scripts/dev logs [service] [docker compose logs options...]
  scripts/dev phpunit <args...>
  scripts/dev pint <args...>
  scripts/dev exec <command> [args...]

Examples:
  scripts/dev artisan test
  scripts/dev mysql -e "show tables"
  scripts/dev logs --tail=100 app
  scripts/dev composer install
  scripts/dev npm run build
USAGE
}

if [ "$#" -eq 0 ]; then
    usage >&2
    exit 64
fi

command_name="$1"
shift

case "${command_name}" in
    php)
        exec "${SCRIPT_DIR}/php" "$@"
        ;;
    composer)
        exec "${SCRIPT_DIR}/composer" "$@"
        ;;
    artisan)
        exec "${SCRIPT_DIR}/artisan" "$@"
        ;;
    npm)
        exec "${SCRIPT_DIR}/npm" "$@"
        ;;
    npx)
        exec "${SCRIPT_DIR}/npx" "$@"
        ;;
    mysql)
        exec "${SCRIPT_DIR}/mysql" "$@"
        ;;
    logs)
        exec "${SCRIPT_DIR}/logs" "$@"
        ;;
    phpunit)
        exec "${SCRIPT_DIR}/phpunit" "$@"
        ;;
    pint)
        exec "${SCRIPT_DIR}/pint" "$@"
        ;;
    exec)
        exec "${SCRIPT_DIR}/container-command.sh" "$@"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "Unknown command: ${command_name}" >&2
        usage >&2
        exit 64
        ;;
esac
